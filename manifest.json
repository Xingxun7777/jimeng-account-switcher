{
  "manifest_version": 3,
  "name": "即梦账号切换器",
  "version": "1.2.2",
  "description": "即梦多账号快速切换、积分/VIP 状态查看、Session 过期告警、账号导入导出",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.jianying.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jimeng-account-switcher@xingxun.local",
      "strict_min_version": "128.0"
    }
  }
}
